{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "optics-pulse",
  "main": "workers/optics-pulse/src/index.ts",
  "compatibility_date": "2026-06-12",
  "assets": {
    "directory": "./artifacts/marketing-os/dist/public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/_edge/*",
      "/api/*"
    ]
  }
}
